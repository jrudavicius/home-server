# Komodo
DOCKER_SOCKET_PATH=/var/run/docker.sock
KOMODO_IMAGE_TAG=2
KOMODO_PORT=9120
KOMODO_BACKUPS_PATH=/srv/server/config/komodo/backups
KOMODO_DATABASE_USERNAME=admin
KOMODO_DATABASE_PASSWORD=change-this-db-password
KOMODO_HOST=http://localhost:9120
KOMODO_INIT_ADMIN_USERNAME=admin
KOMODO_INIT_ADMIN_PASSWORD=change-this-admin-password
KOMODO_FIRST_SERVER_NAME=Local
KOMODO_WEBHOOK_SECRET=change-this-webhook-secret
KOMODO_JWT_SECRET=change-this-jwt-secret
PERIPHERY_ROOT_DIRECTORY=/srv/server

# Plex
PLEX_PORT=32400
PLEX_CLAIM=claim-xxxxxxxxxxxxxxxxxxxx
PLEX_CONFIG_PATH=/srv/server/config/plex-media-server
TRANSCODE_PATH=/srv/server/transcode

# Plex and Transmission media root
MEDIA_PATH=/media/drive

# Transmission
TRANSMISSION_USERNAME=transmission-manager
TRANSMISSION_CONFIG_PATH=/srv/server/config/transmission
TRANSMISSION_USER_PASSWORD_FILE=/srv/server/config/transmission/transmission_user_password.txt
