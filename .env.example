# Komodo
DOCKER_SOCKET_PATH=/var/run/docker.sock
KOMODO_IMAGE_TAG=2
KOMODO_PORT=9120
KOMODO_BACKUPS_PATH=/srv/server/config/komodo/backups
KOMODO_DATABASE_USERNAME=komodo
KOMODO_DATABASE_PASSWORD=change-this-db-password
KOMODO_HOST=http://raspberrypi.local:9120
KOMODO_INIT_ADMIN_USERNAME=julius
KOMODO_INIT_ADMIN_PASSWORD=change-this-admin-password
KOMODO_FIRST_SERVER_NAME=raspberry-pi
KOMODO_WEBHOOK_SECRET=change-this-webhook-secret
KOMODO_JWT_SECRET=change-this-jwt-secret
PERIPHERY_ROOT_DIRECTORY=/srv/server
