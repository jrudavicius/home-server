# Required. Get it from the ngrok dashboard.
NGROK_AUTHTOKEN=change-this-ngrok-authtoken

# Optional. Only used with docker-compose.domain.yml.
NGROK_DOMAIN=

# Local ngrok inspection UI/API port.
NGROK_INSPECT_PORT=4040

# Docker network where the entrypoint and Komodo containers are attached.
NGROK_DOCKER_NETWORK=portainer_network

# Default exposes Komodo directly for external UI access and webhooks.
# Use http://home-server-proxy:80 to expose the Traefik entrypoint instead.
NGROK_TUNNEL_TARGET=http://komodo-core:9120
