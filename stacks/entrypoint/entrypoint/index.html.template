<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>${ENTRYPOINT_TITLE}</title>
    <style>
      :root {
        color-scheme: dark;
        --bg: #121417;
        --panel: #1c2127;
        --panel-strong: #252b32;
        --text: #f3f5f7;
        --muted: #9da8b3;
        --line: #353d46;
        --accent: #6ec6b8;
        --accent-2: #f0b35b;
        --danger: #e67c73;
      }

      * {
        box-sizing: border-box;
      }

      body {
        min-height: 100vh;
        margin: 0;
        background:
          linear-gradient(130deg, rgba(110, 198, 184, 0.14), transparent 32rem),
          linear-gradient(310deg, rgba(240, 179, 91, 0.12), transparent 28rem),
          var(--bg);
        color: var(--text);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
      }

      main {
        width: min(1120px, calc(100% - 32px));
        margin: 0 auto;
        padding: 48px 0;
      }

      header {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 24px;
        padding-bottom: 28px;
        border-bottom: 1px solid var(--line);
      }

      h1 {
        margin: 0;
        font-size: clamp(2rem, 5vw, 4.25rem);
        line-height: 1;
        letter-spacing: 0;
      }

      .subtitle {
        margin: 14px 0 0;
        color: var(--muted);
        font-size: 1.05rem;
      }

      .status {
        min-width: 164px;
        padding: 10px 12px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: rgba(28, 33, 39, 0.76);
        color: var(--muted);
        text-align: right;
        font-variant-numeric: tabular-nums;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 16px;
        margin-top: 28px;
      }

      .service {
        display: grid;
        min-height: 178px;
        padding: 18px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: rgba(28, 33, 39, 0.86);
        color: inherit;
        text-decoration: none;
        transition:
          transform 160ms ease,
          border-color 160ms ease,
          background 160ms ease;
      }

      .service:hover,
      .service:focus-visible {
        transform: translateY(-2px);
        border-color: var(--accent);
        background: var(--panel-strong);
        outline: none;
      }

      .service-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }

      .mark {
        display: inline-grid;
        width: 46px;
        height: 46px;
        place-items: center;
        border-radius: 8px;
        background: #11171b;
        color: var(--accent);
        font-weight: 800;
      }

      .badge {
        color: var(--muted);
        font-size: 0.85rem;
      }

      h2 {
        margin: 26px 0 8px;
        font-size: 1.35rem;
        letter-spacing: 0;
      }

      .description,
      .url {
        margin: 0;
        color: var(--muted);
        line-height: 1.5;
      }

      .url {
        align-self: end;
        overflow-wrap: anywhere;
        font-family:
          ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
          "Liberation Mono", monospace;
        font-size: 0.84rem;
      }

      footer {
        margin-top: 28px;
        color: var(--muted);
        font-size: 0.9rem;
      }

      @media (max-width: 820px) {
        main {
          width: min(100% - 24px, 640px);
          padding: 32px 0;
        }

        header,
        .grid {
          display: grid;
          grid-template-columns: 1fr;
        }

        .status {
          text-align: left;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <header>
        <div>
          <h1>${ENTRYPOINT_TITLE}</h1>
          <p class="subtitle">${ENTRYPOINT_SUBTITLE}</p>
        </div>
        <div class="status" id="clock">Local time</div>
      </header>

      <section class="grid" aria-label="Services">
        <a
          class="service"
          data-url="${ENTRYPOINT_KOMODO_URL}"
          data-host="${KOMODO_TRAEFIK_HOST}"
          data-port="${KOMODO_PORT}"
          data-path="/"
          href="#"
        >
          <div class="service-top">
            <span class="mark">K</span>
            <span class="badge">Control plane</span>
          </div>
          <h2>Komodo</h2>
          <p class="description">Manage deployments, containers, and server resources.</p>
          <p class="url"></p>
        </a>

        <a
          class="service"
          data-url="${ENTRYPOINT_PLEX_URL}"
          data-host="${PLEX_TRAEFIK_HOST}"
          data-port="${PLEX_PORT}"
          data-path="/web"
          href="#"
        >
          <div class="service-top">
            <span class="mark">P</span>
            <span class="badge">Media</span>
          </div>
          <h2>Plex</h2>
          <p class="description">Open the local Plex Media Server dashboard.</p>
          <p class="url"></p>
        </a>

        <a
          class="service"
          data-url="${ENTRYPOINT_TRAEFIK_URL}"
          data-host="${TRAEFIK_DASHBOARD_HOST}"
          data-port="${TRAEFIK_HTTP_PORT}"
          data-path="/dashboard/"
          href="#"
        >
          <div class="service-top">
            <span class="mark">Tf</span>
            <span class="badge">Proxy</span>
          </div>
          <h2>Traefik</h2>
          <p class="description">Inspect routers, services, and proxy health.</p>
          <p class="url"></p>
        </a>

        <a
          class="service"
          data-url="${ENTRYPOINT_GRAFANA_URL}"
          data-host="${GRAFANA_TRAEFIK_HOST}"
          data-port="${GRAFANA_PORT}"
          data-path="/"
          href="#"
        >
          <div class="service-top">
            <span class="mark">G</span>
            <span class="badge">Logs</span>
          </div>
          <h2>Grafana</h2>
          <p class="description">Search container logs and inspect observability dashboards.</p>
          <p class="url"></p>
        </a>

        <a
          class="service"
          data-url="${ENTRYPOINT_TRANSMISSION_URL}"
          data-host="${TRANSMISSION_TRAEFIK_HOST}"
          data-port="${TRANSMISSION_WEB_PORT}"
          data-path="/transmission/web/"
          href="#"
        >
          <div class="service-top">
            <span class="mark">T</span>
            <span class="badge">Transfers</span>
          </div>
          <h2>Transmission</h2>
          <p class="description">Manage torrent activity from the web interface.</p>
          <p class="url"></p>
        </a>
      </section>

      <footer>
        Configure custom links with ENTRYPOINT_KOMODO_URL, ENTRYPOINT_PLEX_URL,
        ENTRYPOINT_GRAFANA_URL, ENTRYPOINT_TRAEFIK_URL, and
        ENTRYPOINT_TRANSMISSION_URL.
      </footer>
    </main>

    <script>
      function cleanPath(path) {
        return path || "/";
      }

      function localUrlFor(port, path) {
        if (!port) {
          return "";
        }

        var protocol = window.location.protocol || "http:";
        var currentPort = window.location.port;
        var portSegment = port === "80" ? "" : ":" + port;

        if (currentPort && currentPort === port) {
          portSegment = window.location.port ? ":" + window.location.port : "";
        }

        return protocol + "//" + window.location.hostname + portSegment + cleanPath(path);
      }

      function hostUrlFor(host, path) {
        if (!host) {
          return "";
        }

        var protocol = window.location.protocol || "http:";
        return protocol + "//" + host + cleanPath(path);
      }

      document.querySelectorAll(".service").forEach(function (service) {
        var configuredUrl = service.getAttribute("data-url").trim();
        var host = service.getAttribute("data-host").trim();
        var port = service.getAttribute("data-port").trim();
        var path = service.getAttribute("data-path").trim();
        var url = configuredUrl || localUrlFor(port, path) || hostUrlFor(host, path);
        service.href = url;
        service.querySelector(".url").textContent = url;
      });

      function updateClock() {
        var formatter = new Intl.DateTimeFormat(undefined, {
          hour: "2-digit",
          minute: "2-digit",
          weekday: "short"
        });
        document.getElementById("clock").textContent = formatter.format(new Date());
      }

      updateClock();
      window.setInterval(updateClock, 30000);
    </script>
  </body>
</html>
